# AMap server-side API key
# Apply at: https://console.amap.com/dev/key/app
AMAP_API_KEY=your_amap_api_key_here

# AMap web key for frontend JS usage
AMAP_WEB_KEY=your_amap_web_key_here

# Prefer Hello-Agents MCPTool-based AMap access
USE_AMAP_MCP=true

# Unsplash API key
# Apply at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# LLM API (OpenAI / MiniMax / other OpenAI-compatible providers)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=auto
LLM_MODEL=gpt-4.1-mini

# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000
